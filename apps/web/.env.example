# Where the FastAPI backend lives (used by next.config.js rewrites for fetch)
API_BASE_URL=http://127.0.0.1:8000

# Absolute URL used by EventSource (bypasses dev-server SSE buffering).
# Same value as API_BASE_URL for local; in prod, point at your Render URL.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
