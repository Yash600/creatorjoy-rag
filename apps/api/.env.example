# Postgres (Neon) — must include `?sslmode=require`
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/creatorjoy?sslmode=require

# Groq — get a free key at https://console.groq.com
GROQ_API_KEY=gsk_xxx

# Models
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_WHISPER_MODEL=whisper-large-v3
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000

# Optional: cap very long transcripts (in seconds) to control cost
MAX_VIDEO_DURATION_SECONDS=5400

# Optional: cache TTL for video metadata refresh (in seconds)
VIDEO_CACHE_TTL_SECONDS=86400

# ─── yt-dlp authentication (recommended for max reliability) ──────────────
# YouTube blocks unauthenticated yt-dlp on certain protected videos.
# Pick AT MOST ONE of the two options below; if both are blank, the app
# automatically tries iOS → Android → web player clients in sequence.
#
# OPTION 1 (best for local dev) — read cookies from your installed browser.
# Make sure you're logged into YouTube in that browser. Note: Chrome on
# Windows requires the browser to be CLOSED (it locks its cookie database).
# Firefox/Edge work while open.
# Valid values: chrome, firefox, edge, safari, brave, opera, vivaldi
YT_COOKIES_BROWSER=

# OPTION 2 (best for production) — point at an exported Netscape-format
# cookies.txt. Use the "Get cookies.txt LOCALLY" Chrome extension to export.
YT_COOKIES_FILE=
